import numpy as np

for node in sfi_nodes:
    # --- 2. Calculate Utility (U) ---
    # Proxy: A node with high persistence and low friction is 'useful'.
    # U = P - F
    node_P = node.get('P', 0.0)
    node_F = node.get('F', 0.0)
    node['U'] = node_P - node_F

    # --- 3. Calculate Tolerance (T) ---
    # Proxy: A node with high absorption and low friction has high tolerance.
    # T = A / (1 + F)
    node_A = node.get('A', 0.0)
    # Ensure 1 + F is not zero to prevent division by zero
    if (1 + node_F) > 0:
        node['T'] = node_A / (1 + node_F)
    else:
        node['T'] = np.inf # If 1+F is 0 or negative, assume infinite tolerance for stability issues

    # --- 4. Calculate Extraction (X) ---
    # X = incoming_value - reciprocal_return
    # incoming_value is perturbations_received
    # reciprocal_return is outgoing_signal_value * R
    incoming_value = node.get('perturbations_received', 0)
    outgoing_value = node.get('num_points', 0)
    node_R = node.get('R', 0.0)

    node['X'] = incoming_value - (outgoing_value * node_R)

