               (t_event['start_time'] - node['start_time']) <= time_window_for_expansion:

                # Get UMAP centroid for the transient event
                t_event_umap_points = np.array([[p['umap_dim_1'], p['umap_dim_2']] for p in t_event['data_points'] if 'umap_dim_1' in p and 'umap_dim_2' in p])
                if len(t_event_umap_points) > 0:
                    t_event_umap_centroid = np.mean(t_event_umap_points, axis=0)

                    # Check if the transient event's centroid is spatially close to any point in the SFI node's trajectory
                    is_spatially_close = False
                    for sfi_point in node_umap_points:
                        if calculate_euclidean_distance(t_event_umap_centroid, sfi_point) <= umap_proximity_threshold_e:
                            is_spatially_close = True
                            break

                    if is_spatially_close:
                        new_clusters_caused_by_node += 1

    # E = new_clusters_caused_by_node / time (normalized by node's duration for simplicity)
    # Or, simpler for prototype: just the count of new clusters caused.
    node['E'] = new_clusters_caused_by_node

