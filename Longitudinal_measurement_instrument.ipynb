    node_umap_points = np.array([[p['umap_dim_1'], p['umap_dim_2']] for p in node['data_points'] if 'umap_dim_1' in p and 'umap_dim_2' in p])

    anomaly_score = 0.0
    if len(node_umap_points) > 0:
        umap_centroid = np.mean(node_umap_points, axis=0)
        distances_to_centroid = [calculate_euclidean_distance(point, umap_centroid) for point in node_umap_points]
        anomaly_score = np.mean(distances_to_centroid) # Average deviation from centroid

    # --- Combine for Friction (F) ---
    # F = variance(embedding_velocity) + drop(C) + anomaly_score
    node['F'] = embedding_velocity_variance + drop_C + anomaly_score

    # --- Calculate Absorption (A) ---
    # --- 1. perturbations_received ---
    # To simplify for the prototype, we need transient_events defined globally
    # (from the 'Define SFI Nodes' subtask)
    # We'll need to define 'spatially close' - let's use a simple UMAP distance threshold.
    perturbations_received = 0
    if 'transient_events' in globals(): # Check if transient_events is defined
        node_umap_min = np.min(node_umap_points, axis=0) if len(node_umap_points) > 0 else np.array([0,0])
        node_umap_max = np.max(node_umap_points, axis=0) if len(node_umap_points) > 0 else np.array([0,0])
        node_umap_center = np.mean(node_umap_points, axis=0) if len(node_umap_points) > 0 else np.array([0,0])

        # Define a spatial proximity threshold in UMAP space
        # This could be data-driven, but for prototype, a heuristic based on node's UMAP spread
        # Let's say, 1.5 times the average deviation of the node itself, or a fixed value.
        # For simplicity, let's use a fixed threshold (e.g., 2.0 in UMAP space)
        proximity_threshold_umap = 2.0

        for t_event in transient_events:
            t_event_umap_points = np.array([[p['umap_dim_1'], p['umap_dim_2']] for p in t_event['data_points'] if 'umap_dim_1' in p and 'umap_dim_2' in p])
            if len(t_event_umap_points) > 0:
                t_event_umap_centroid = np.mean(t_event_umap_points, axis=0)

                # Check if the transient event's centroid is close to any point in the SFI node's trajectory
                for sfi_point in node_umap_points:
                    if calculate_euclidean_distance(t_event_umap_centroid, sfi_point) <= proximity_threshold_umap:
                        perturbations_received += 1
                        break # Count once per transient event near this node

    # --- 2. state_change ---
    # For this prototype, use the magnitude of the Direction (D) vector as a primary indicator of state change.
    # More sophisticated calculation would involve tracking changes in P and C over the node's lifetime.
    state_change = np.linalg.norm(node['D']) if 'D' in node and len(node['D']) == 2 else 0.0

    # --- Combine for Absorption (A) ---
    # A = perturbations_received / state_change
    node['A'] = perturbations_received / state_change if state_change > 0 else np.inf # Handle division by zero


print(f"Calculated Friction (F) and Absorption (A) for {len(sfi_nodes)} SFI Nodes.")

print("\nFirst 3 SFI Nodes with calculated F and A:")
