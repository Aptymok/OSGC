for node in sfi_nodes:
    # --- 1. Calculate Expansion (E) ---
    # Initialize count for new clusters caused by this node
    new_clusters_caused_by_node = 0

    # Get UMAP trajectory points for the current SFI node
    node_umap_points = np.array([[p['umap_dim_1'], p['umap_dim_2']] for p in node['data_points'] if 'umap_dim_1' in p and 'umap_dim_2' in p])

